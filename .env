# ================================================
# LiveCalicut — Environment Variables
# ================================================
# NEXT_PUBLIC_* vars are safe for the browser.
# Never put secrets here — use .env.local for those.
#
# ⚠️  REQUIRED: Replace with your real Supabase credentials
# Get them from: https://supabase.com/dashboard → Project Settings → API
# ================================================

# Supabase Project (PUBLIC — embedded in client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_REAL_ANON_KEY

# App Identity (PUBLIC)
NEXT_PUBLIC_APP_NAME=LiveCalicut Hyperlocal Portal
NEXT_PUBLIC_APP_DEFAULT_CITY=Kozhikode (Calicut)
NEXT_PUBLIC_APP_DEFAULT_LAT=11.2588
NEXT_PUBLIC_APP_DEFAULT_LNG=75.7804
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_JOBS=true
NEXT_PUBLIC_ENABLE_REALTIME=true
